<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="end" android:padding="6dp">
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:maxWidth="260dp"
        android:background="@drawable/bubble_sent" android:padding="10dp">
        <TextView android:id="@+id/tvContenido" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        <TextView android:id="@+id/tvHora" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="10sp" android:textColor="#DDFFFFFF"
            android:layout_gravity="end" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tvFueraHorario" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="10sp" android:textColor="#FFFFCC"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>
