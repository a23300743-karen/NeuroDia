<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Glucosa -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Glucosa (mg/dL)" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Valor de glucosa"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGlucosa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Momento de medición" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <RadioGroup android:id="@+id/rgMomento" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton android:id="@+id/rbAyunas" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Ayunas" android:checked="true"
                android:layout_marginEnd="16dp"/>
            <RadioButton android:id="@+id/rbPostprandial" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Postprandial"
                android:layout_marginEnd="16dp"/>
            <RadioButton android:id="@+id/rbNocturno" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Nocturno"/>
        </RadioGroup>

        <!-- Dolor -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Intensidad de dolor (0-10)" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="0 = sin dolor, 10 = dolor máximo"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDolor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Localizaciones -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Localización del dolor" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="3" android:layout_marginBottom="24dp">
            <CheckBox android:id="@+id/cbPies"    android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pies"    android:layout_columnWeight="1"/>
            <CheckBox android:id="@+id/cbManos"   android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manos"   android:layout_columnWeight="1"/>
            <CheckBox android:id="@+id/cbPiernas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Piernas" android:layout_columnWeight="1"/>
            <CheckBox android:id="@+id/cbBrazos"  android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brazos"  android:layout_columnWeight="1"/>
            <CheckBox android:id="@+id/cbEspalda" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Espalda" android:layout_columnWeight="1"/>
            <CheckBox android:id="@+id/cbCabeza"  android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cabeza"  android:layout_columnWeight="1"/>
        </GridLayout>

        <!-- Síntomas -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Síntomas presentes" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="24dp">
            <CheckBox android:id="@+id/cbEntumecimiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entumecimiento"/>
            <CheckBox android:id="@+id/cbHormigueo"      android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hormigueo"/>
            <CheckBox android:id="@+id/cbQuemazon"       android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quemazón"/>
            <CheckBox android:id="@+id/cbDebilidad"      android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Debilidad muscular"/>
            <CheckBox android:id="@+id/cbMareos"         android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mareos"/>
        </LinearLayout>

        <!-- Notas -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notas adicionales (opcional)"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"/>
        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar registro"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
