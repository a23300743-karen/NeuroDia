<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NeuroDiaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeuroDia"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- LOGIN -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- PACIENTE -->
        <activity android:name=".ui.paciente.MonitoreoActivity"
            android:label="Monitoreo Diario"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.paciente.PerfilActivity"
            android:label="Mi Perfil"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.paciente.HistorialActivity"
            android:label="Historial" />
        <activity android:name=".ui.paciente.AlertasPacienteActivity"
            android:label="Alertas" />
        <activity android:name=".ui.paciente.ChatPacienteActivity"
            android:label="Chat con mi médico"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.paciente.MedicamentosActivity"
            android:label="Medicamentos y comorbilidades"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.paciente.PacienteHomeActivity"
            android:label="NeuroDia" />

        <!-- MÉDICO -->
        <activity android:name=".ui.medico.DashboardMedicoActivity"
            android:label="Dashboard" />
        <activity android:name=".ui.medico.PacientesActivity"
            android:label="Mis Pacientes" />
        <activity android:name=".ui.medico.PacienteDetalleActivity"
            android:label="Detalle del Paciente"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.medico.AlertasMedicoActivity"
            android:label="Alertas Pendientes" />
        <activity android:name=".ui.medico.ChatMedicoActivity"
            android:label="Chat"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.medico.AltaPacienteActivity"
            android:label="Dar de alta paciente"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.medico.HorarioActivity"
            android:label="Horario de atención"
            android:windowSoftInputMode="adjustResize" />

    </application>
</manifest>
